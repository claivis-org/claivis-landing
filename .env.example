# ── Claivis Landing Page — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Waitlist API ───────────────────────────────────────────────────────────────
# Option A: Loops.so (recommended — Nigerian-friendly, generous free tier)
# Airtable (used by app/api/waitlist/route.ts)
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
# Optional if your Airtable setup uses different names
# AIRTABLE_TABLE_NAME=Waitlist
# AIRTABLE_STATUS_FIELD_NAME=Status
# Optional. Only set this if the select option already exists in Airtable.
# AIRTABLE_DEFAULT_STATUS=New

# Legacy Loops variables
# LOOPS_API_KEY=your_loops_api_key_here
# LOOPS_MAILING_LIST_ID=your_list_id_here

# Option B: Mailchimp
# MAILCHIMP_API_KEY=your_key
# MAILCHIMP_LIST_ID=your_list_id
# MAILCHIMP_SERVER_PREFIX=us1

# Option C: Supabase (if storing in your own DB)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ── WhatsApp ───────────────────────────────────────────────────────────────────
# Replace YOUR_GROUP_LINK in page.tsx with your actual WhatsApp invite link
# e.g. https://chat.whatsapp.com/AbCdEfGhIjKlMnOpQrStUv

# ── Analytics (optional) ──────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
